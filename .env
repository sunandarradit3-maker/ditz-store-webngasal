# Rename this file to .env and fill in your API credentials
# QRIS.PW API credentials
QRIS_API_KEY=your_qris_api_key
QRIS_API_SECRET=your_qris_api_secret

# ClaidexPayment credentials (optional)
CLAIDEX_CLIENT_KEY=your_claidex_client_key
CLAIDEX_CLIENT_SECRET=your_claidex_client_secret

# Server port
PORT=3000